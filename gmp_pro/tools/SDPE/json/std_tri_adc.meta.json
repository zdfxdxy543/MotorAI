{
  "module_id": "std_tri_adc",
  "display_name": "Triple ADC Channel",
  "c_struct": "tri_adc_channel_t",
  "header_file": "adc_channel.h",
  "execution_model": {
    "1_state_declaration": {
      "instance_type": "tri_adc_channel_t"
    },
    "2_basic_information": [
      {
        "name": "adc_res",
        "type": "fast_gt",
        "label": "ADC Resolution (Bits)",
        "default": 12
      },
      {
        "name": "iqn",
        "type": "fast_gt",
        "label": "IQ Format Number",
        "default": 24
      }
    ],
    "3_initialization": {
      "templates": [
        {
          "template_id": "init_current_shunt",
          "display_name": "Current Sensing (Shunt)",
          "required_params": [
            {
              "name": "v_ref",
              "type": "parameter_gt"
            },
            {
              "name": "v_sens",
              "type": "parameter_gt",
              "description": "Sensitivity V/A"
            },
            {
              "name": "v_bias",
              "type": "parameter_gt"
            }
          ],
          "c_snippet": "ctl_init_tri_adc_channel(&{INSTANCE}, ctl_gain_calc_generic({v_ref}, {v_sens}, 1.0f), ctl_bias_calc_via_Vref_Vbias({v_ref}, {v_bias}), {adc_res}, {iqn});"
        }
      ]
    },
    "4_input_callback": {
      "templates": [
        {
          "template_id": "step_tri_adc",
          "required_params": [
            {
              "name": "raw_a",
              "type": "adc_gt",
              "is_hardware_mapped": true
            },
            {
              "name": "raw_b",
              "type": "adc_gt",
              "is_hardware_mapped": true
            },
            { 
              "name": "raw_c",
              "type": "adc_gt",
              "is_hardware_mapped": true
            }
          ],
          "c_snippet": "ctl_step_adc_tri_channel(&{INSTANCE}, {raw_a}, {raw_b}, {raw_c});"
        }
      ]
    }
  }
}