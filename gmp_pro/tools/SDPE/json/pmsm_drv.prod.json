{
  "schema_version": "1.0",
  "node_type": "Product",
  "product_name": "pmsm_drv",
  "description": "FOC Motor Drive Product MVP",
  "target_mcu": "Generic_MCU",
  
  "instances": {
    "Axis1": {
      "instance_ref": "Drive_Axis1"
    }
  },
  
  "peripheral_macros": [
    {"name": "PROD_AXIS1_PWM_TIM", "value": "TIM1", "description": "Main PWM Timer for Axis 1"},
    {"name": "PROD_AXIS1_ADC_MOD", "value": "ADC1", "description": "Main ADC Module for Axis 1"}
  ],
  
  "execution_paradigms": {
    "input_callback": {
      "paradigm_type": "dma_array_polling",
      "description": "Read ADC raw values from a user-defined DMA buffer array."
    },
    "output_callback": {
      "paradigm_type": "timer_ccr_update",
      "description": "Write PWM compare values directly to Timer CCR registers."
    }
  },
  
  "hardware_routing": {
    "Axis1.I_Phase.raw_a": "adc1_dma_buf[0]",
    "Axis1.I_Phase.raw_b": "adc1_dma_buf[1]",
    "Axis1.I_Phase.raw_c": "adc1_dma_buf[2]",
    
    "Axis1.Inverter.cmp_a": "PROD_AXIS1_PWM_TIM->CCR1",
    "Axis1.Inverter.cmp_b": "PROD_AXIS1_PWM_TIM->CCR2",
    "Axis1.Inverter.cmp_c": "PROD_AXIS1_PWM_TIM->CCR3"
  }
}