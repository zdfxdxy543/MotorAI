{
  "task_type": "constant_speed_control",
  "objective": "Reach and maintain target velocity with small overshoot and low steady-state error.",
  "signals": {
    "actual_velocity": "measured_velocity",
    "target_velocity": "target_velocity",
    "id_feedback": "id",
    "iq_feedback": "iq",
    "iq_ref": "iq_ref"
  },
  "metrics": [
    {
      "metric_name": "rise_time",
      "signal": "actual_velocity",
      "target_signal": "target_velocity",
      "weight": 0.25,
      "optimization_direction": "minimize",
      "good_threshold": 0.05,
      "bad_threshold": 1.0
    },
    {
      "metric_name": "steady_state_error",
      "signal": "actual_velocity",
      "target_signal": "target_velocity",
      "weight": 0.25,
      "optimization_direction": "minimize",
      "good_threshold": 0.01,
      "bad_threshold": 0.2
    },
    {
      "metric_name": "id_deviation",
      "signal": "id_feedback",
      "target_value": 0,
      "weight": 0.15,
      "optimization_direction": "minimize",
      "good_threshold": 0.01,
      "bad_threshold": 0.2
    },
    {
      "metric_name": "iq_response_overshoot",
      "signal": "iq_feedback",
      "target_signal": "iq_ref",
      "weight": 0.10,
      "optimization_direction": "minimize",
      "good_threshold": 0.05,
      "bad_threshold": 0.5
    }
  ]
}