  Node1 [id="Node000001",label="ZonRi DRV8301 Module\l Hardware Abstraction Layer",height=0.2,width=0.4,color="gray40", fillcolor="grey60", style="filled", fontcolor="black",tooltip="Parameters for the ZonRi DRV8301 motor driver module."];
  Node6 [id="Node000006",label="Sensing Circuit Parameters",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$group__hal__zonri__drv8301__circuits.html",tooltip="This section defines the detailed electrical parameters of all sensing circuits."];
  Node4 [id="Node000004",label="Physical Operating\l Limits",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$group__hal__zonri__drv8301__limits.html",tooltip="This section defines the boundary conditions for the safe physical operation of the board."];
  Node7 [id="Node000007",label="Default Parameter Mapping",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$group__hal__zonri__drv8301__mapping.html",tooltip="This section maps the board-specific parameters to the generic 'MY_BOARD_' macros."];
  Node3 [id="Node000003",label="Nameplate",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$group__hal__zonri__drv8301__nameplate.html",tooltip="This section records the key hardware models of the board for identification and traceability."];
  Node5 [id="Node000005",label="Sensing Topology",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$group__hal__zonri__drv8301__topology.html",tooltip="This section describes the type and layout of the onboard sensors."];
